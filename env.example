# GitHub Chat — environment variables
# Copy to .env and fill in your keys.
# GROQ is preferred (faster, higher RPM). GEMINI is the fallback.
# At least one LLM key is required.

GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: GitHub personal access token (raises rate limit from 60 to 5000 req/hr)
GITHUB_TOKEN=your_github_token_here

# Optional: restrict CORS to your frontend origin in production
# FRONTEND_ORIGIN=https://your-app.vercel.app
